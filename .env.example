# GGB Teststand Environment Configuration
# 
# This file serves as a template for environment variables that may be
# used in future versions. Currently, most configuration is hardcoded
# in the application files.
#
# To use:
#   1. Copy this file to .env
#   2. Update values for your specific hardware
#   3. Modify docker_compose.yml to read these variables
#
# Note: .env file should NOT be committed to version control

###############################################################################
# MongoDB Configuration
###############################################################################

# MongoDB root credentials (currently disabled in docker_compose.yml)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme

# MongoDB connection string for applications
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=ggb_teststand

###############################################################################
# Network Configuration
###############################################################################

# LabJack T7 Data Acquisition Device
LABJACK_IP=192.168.8.148
LABJACK_PORT=502
LABJACK_PROTOCOL=TCP

###############################################################################
# Serial Port Configuration
###############################################################################

# Serial port assignments (for reference)
# These paths are currently hardcoded in node-red-data/flows.json
# Update flows.json if your devices map differently

# Debug serial port (FTDI #1)
SERIAL_DEBUG=/dev/ttyUSB0
SERIAL_DEBUG_BAUD=115200

# Reader 1 RS485 (FTDI #2)
SERIAL_READER1=/dev/ttyUSB1
SERIAL_READER1_BAUD=115200

# Reader 2 RS485 (FTDI #3)
SERIAL_READER2=/dev/ttyUSB2
SERIAL_READER2_BAUD=115200

# ESP32 Serial Port
SERIAL_ESP32=/dev/ttyACM0
SERIAL_ESP32_BAUD=115200

###############################################################################
# Power Supply Configuration
###############################################################################

# Siglent Power Supply VISA Resource String
# This is currently hardcoded in stm32_flash_api/app.py
# Update app.py if your power supply has a different serial number
POWER_SUPPLY_VISA=USB0::0x0483::0x7540::SPD3ECAC3R0303::INSTR

# Power supply communication delay (seconds)
POWER_SUPPLY_DELAY=0.5

###############################################################################
# STM32 Flash API Configuration
###############################################################################

# STM32 Flash API service
FLASH_API_HOST=0.0.0.0
FLASH_API_PORT=5000

# STM32 Cube Programmer CLI path (inside container)
STM32_PROGRAMMER_CLI=/usr/local/STMicroelectronics/STM32Cube/STM32CubeProgrammer/bin/STM32_Programmer_CLI

# Upload directory for firmware files
UPLOAD_FOLDER=/home/ubuntu/ggb_test_bins/

# ST-Link programmer index (0 if only one connected)
STLINK_INDEX=0

###############################################################################
# Node-RED Configuration
###############################################################################

# Node-RED port (configurable in settings.js)
NODE_RED_PORT=1880

# Node-RED credential secret (for encrypting credentials)
# NODE_RED_CREDENTIAL_SECRET=your-secret-key-here

###############################################################################
# Filebrowser Configuration
###############################################################################

# Filebrowser port
FILEBROWSER_PORT=8080

# Filebrowser root directory (inside container)
FILEBROWSER_ROOT=/srv

###############################################################################
# Mongo Express Configuration
###############################################################################

# Mongo Express web interface
MONGO_EXPRESS_PORT=8081
ME_CONFIG_MONGODB_SERVER=mongodb
# ME_CONFIG_MONGODB_ADMINUSERNAME=admin
# ME_CONFIG_MONGODB_ADMINPASSWORD=password

###############################################################################
# File Upload Service Configuration
###############################################################################

# File upload service (if enabled)
FILE_UPLOAD_PORT=5005
FILE_UPLOAD_SHARED_DATA=/shared_data

###############################################################################
# Development/Debug Settings
###############################################################################

# Enable debug logging
DEBUG=false

# Docker compose project name
COMPOSE_PROJECT_NAME=ggb-teststand

###############################################################################
# Security Notes
###############################################################################

# IMPORTANT:
# - Never commit .env file to version control
# - Add .env to .gitignore
# - Use strong passwords in production
# - MongoDB authentication is currently disabled
# - Docker containers run in privileged mode for USB access
# - Consider network isolation in production environments

###############################################################################
# Usage Examples
###############################################################################

# To use these variables in docker_compose.yml, reference them like:
#
# services:
#   mongodb:
#     environment:
#       - MONGO_INITDB_ROOT_USERNAME=${MONGO_INITDB_ROOT_USERNAME}
#       - MONGO_INITDB_ROOT_PASSWORD=${MONGO_INITDB_ROOT_PASSWORD}
#
# To use in Python (stm32_flash_api/app.py):
#
# import os
# power_supply_visa = os.getenv('POWER_SUPPLY_VISA', 'default_value')
#
# To use in Node-RED settings.js:
#
# const mongoHost = process.env.MONGO_HOST || 'mongodb';
